{% extends "base.njk" %}

{% block content %}
<article class="work">

  <header class="work-header">
    <nav class="meta">
      <a href="/works/">返回作品列表</a>
    </nav>
    <h1 class="work-title">
      {{ title }}
    </h1>
    
    <div class="meta">
      {% if workType %}
        <span class="work-type">
          {{ workType | capitalize }}
        </span>
      {% endif %}
    &nbsp; <!--插一個空白-->
    <time datetime="{{ page.date | readableDate }}">{{ page.date | readableDate }}</time>
    </div>
  </header>

  <hr class="work-divider" />

  <section class="work-content">
    {{ content | safe }}
  </section>

  <hr class="work-divider" />

  <nav class="meta">
    <a href="/works/">返回作品列表</a>
  </nav>

</article>
{% endblock %}