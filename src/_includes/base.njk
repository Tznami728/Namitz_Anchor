<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="layout">
    <main>
      {% block content %}{% endblock %}
    </main>
  </div>

  <!-- 底部導覽列 -->
  <footer class="bottom-nav">
    <nav class="bottom-nav-content">
      <a href="/" class="{% if page.url == '/' %}active{% endif %}">錨點</a>
      <a href="/works/" class="{% if page.url == '/works/' %}active{% endif %}">編曲</a>
      <a href="/gallery/" class="{% if page.url == '/gallery/' %}active{% endif %}">寫真</a>
      <a href="/posts/" class="{% if page.url == '/posts/' %}active{% endif %}">雜談</a>
      <a href="/links/" class="{% if page.url == '/links/' %}active{% endif %}">連結</a>
    </nav>
  </footer>
</body>
</html>