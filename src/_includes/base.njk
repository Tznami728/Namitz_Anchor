<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="layout">
    <aside>
    <h2><a href="/">Home</a></h2>
    <h2><a href="/works">Gallery</a></h2>
    <h2><a href="{{ (collections.posts | first).url }}">Blog</a></h2>
    <ul>
      {% for post in collections.posts %}
      {% set isCurrent = post.url == page.url %}
      <li class="{% if isCurrent %}active{% endif %}">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      {% endfor %}
    </ul>
    </aside>

    <main>
      {% block content %}{% endblock %}
    </main>
  </div>
</body>
</html>
