---
title: 部落格
---

{% extends "base.njk" %}

{% block content %}
<header>
  <h1>
    {{title}}
  </h1>
  <p>
    一些個人記錄。
  </p>
  <hr>
</header>

<body>
  <!-- 最新文章部分 -->
  {% if collections.posts.length > 0 %}
    {% set latestPost = collections.posts[0] %}
    <section>
      <article>
        <b>最新文章- &nbsp;<a href="{{ latestPost.url }}">{{ latestPost.data.title }}</a></b>
        <p>{{ latestPost.templateContent | striptags | truncate(125, true, '...') }}</p>
        <p class="meta">{{ latestPost.data.date | strftime("%Y-%m-%d") }}
        <a href="{{ latestPost.url }}">查看更多</a>
        </p>
      </article>
      <hr>
    </section>
  {% endif %}

  <!-- 所有文章列表 -->
  {% set currentYear = null %}
  
  {% for post in collections.posts %}
    {% if post.data.date %}
      {% set postYear = post.data.date | strftime("%Y") %}
      
      {% if postYear != currentYear %}
        {% if currentYear != null %}</ul>{% endif %}
        <h2>{{ postYear }}</h2>
        <ul>
        {% set currentYear = postYear %}
      {% endif %}
      
      {% set isCurrent = post.url == page.url %}
      <li class="{% if isCurrent %}active{% endif %}">
        <span class="meta">{{ post.data.date | strftime("%m-%d") }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      <br>
    {% endif %}
  {% endfor %}
  
  {% if currentYear != null %}
    </ul>
  {% endif %}
</body>

{% endblock %}