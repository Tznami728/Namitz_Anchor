---
title: 部落格
---

{% extends "base.njk" %}

{% block content %}
<header>
  <h1>
    {{title}}
  </h1>
  <p>
    就是一些廢文。
  </p>
</header>

<body>
  <!-- {% set sortedPosts = collections.posts | reverse %} -->
  {% set currentYear = null %}
  
  {% for post in collections.posts %}
    {% if post.data.date %}
      {% set postYear = post.data.date | strftime("%Y") %}
      
      {% if postYear != currentYear %}
        {% if currentYear != null %}</ul>{% endif %}
        <h2>{{ postYear }}</h2>
        <ul>
        {% set currentYear = postYear %}
      {% endif %}
      
      {% set isCurrent = post.url == page.url %}
      <li class="{% if isCurrent %}active{% endif %}">
        <span class="post-date">{{ post.data.date | strftime("%m-%d") }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      <br>
    {% endif %}
  {% endfor %}
  
  {% if currentYear != null %}
    </ul>
  {% endif %}
</body>

