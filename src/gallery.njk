---
title: 相片集
---

{% extends "base.njk" %}

{% block content %}
  <header>
    <h1>
      {{ title }}
    </h1>
  </header>

  <div class="gallery-grid">
    {% for photo in collections.photos %}
      <div class="gallery-item">
        <img src="{{ photo.url }}" alt="{{ photo.name }}" loading="lazy">
      </div>
    {% endfor %}
  </div>

<!-- 
改用 gallery-grid 容器和循環遍歷所有圖片
使用 loading="lazy" 優化效能
-->
{% endblock %}